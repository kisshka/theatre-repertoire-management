@using AntDesign
@using Microsoft.AspNetCore.Components.Forms
@using TheatreManagement.Client.Helpers.SelectItems
@using TheatreManagement.Shared.DTOs
@using TheatreManagement.Shared.DTOs.Employees

<Modal Visible="@Visible"
       Title="Создание отчета"
       OnOk="HandleOk"
       OnCancel="HandleCancel"
       ConfirmLoading="@isDownloading"
       MaskClosable="@false">

    <Form Model="@Model"
          OnFinishFailed="@OnFinishFailed"
          @ref="@FormRef">

        <FormItem Label="Даты проведения" Required>
            <RangePicker TValue="DateTime[]"
                         ShowTime="false"
                         AllowClear="false"
                         ChangeOnClose="true"
                         @bind-Value="@dateRange"
                         Format="dd.MM.yyyy" />
        </FormItem>

        <FormItem Label="Тип мероприятий">
            <Select Mode="SelectMode.Default"
                    DataSource="@eventTypes"
                    @bind-Value="@selectedType"
                    LabelName="Name"
                    ValueName="Value"
                    Placeholder="Выберите тип"
                    AllowClear="true">
            </Select>
        </FormItem>

    </Form>
</Modal>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }
    [Parameter] public int EmployeeId { get; set; } = -1;

    [Inject] private NavigationManager Navigation { get; set; }
    [Inject] private MessageService Message { get; set; }

    private Form<EmployeeDto> FormRef { get; set; }
    private EmployeeDto Model { get; set; } = new();

    private DateTime[] dateRange = new DateTime[] { DateTime.Now, DateTime.Now.AddDays(7) };
    private bool isDownloading = false;
    private string? selectedType { get; set; } = null;

    private List<SelectItem<string>> eventTypes = new()
    {
        new SelectItem<string> { Name = "Стационар", Value = "stationar" },
        new SelectItem<string> { Name = "Гастроли", Value = "tour" },
        new SelectItem<string> { Name = "Выезд", Value = "visit" },
        new SelectItem<string> { Name = "Все", Value = null }
    };

    private string GetReportUrl()
    {
        if (dateRange == null || dateRange.Length < 2 || dateRange[0] == default || dateRange[1] == default)
        {
            return "#";
        }

        var apiBaseUrl = "https://localhost:7260";
        var url = $"{apiBaseUrl}/api/Reports/events-report?start={dateRange[0]:yyyy-MM-dd}&end={dateRange[1]:yyyy-MM-dd}";

        if (!string.IsNullOrWhiteSpace(selectedType) && selectedType != "Все")
        {
            url += $"&type={selectedType}";
        }

        if (EmployeeId > 0)
        {
            url += $"&employeeId={EmployeeId}";
        }

        return url;
    }

    private async Task HandleOk()
    {
        //Проверка дат
        if (dateRange == null || dateRange.Length < 2 || dateRange[0] == default || dateRange[1] == default)
        {
            Message.Error("Выберите период дат");
            return;
        }

        isDownloading = true;
        StateHasChanged();

        try
        {
            var url = GetReportUrl();

            if (url != "#")
            {
                Navigation.NavigateTo(url, true);
                await Task.Delay(200);

                Visible = false;
                await VisibleChanged.InvokeAsync(false);
                await OnSuccess.InvokeAsync();
                ResetForm();

                Message.Success("Отчет успешно сформирован");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Ошибка: {ex.Message}");
        }
        finally
        {
            isDownloading = false;
            StateHasChanged();
        }
    }

    private void OnFinishFailed(EditContext editContext)
    {
        foreach (var error in editContext.GetValidationMessages())
        {
            Message.Error(error);
        }
    }

    private async Task HandleCancel()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
        ResetForm();
    }

    private void ResetForm()
    {
        dateRange = new DateTime[] { DateTime.Now, DateTime.Now.AddDays(7) };
        selectedType = null;
        Model = new EmployeeDto();
        FormRef?.Reset();
        StateHasChanged();
    }
}