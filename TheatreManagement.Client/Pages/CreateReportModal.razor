@using AntDesign
@using Microsoft.AspNetCore.Components.Forms
@using TheatreManagement.Client.Helpers.SelectItems
@using TheatreManagement.Shared.DTOs
@using TheatreManagement.Shared.DTOs.Employees

<Modal Visible="@Visible"
       Title="@Title"
OnOk="HandleOk"
OnCancel="HandleCancel"
ConfirmLoading="@isDownloading"
MaskClosable="@false">

    <Form Model="@Model"
    OnFinishFailed="@OnFinishFailed"
    @ref="@FormRef">

        <FormItem Label="Временной отрезок">
            <RangePicker TValue="DateTime[]"
            ShowTime="false"
            AllowClear="false"
            ChangeOnClose="true"
            @bind-Value="@dateRange"
            Format="dd.MM.yyyy" />
        </FormItem>

        <FormItem Label="Тип мероприятий">
            <Select Mode="SelectMode.Default"
                    DataSource="@SelectItemValues.ReportEventTypes"
            @bind-Value="@selectedType"
            LabelName="Name"
            ValueName="Value"
            Placeholder="Выберите тип"
            AllowClear="false">
            </Select>
        </FormItem>

        <Checkbox Label="Включить составы" @bind-Value="@includeCast"></Checkbox>

    </Form>
</Modal>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }
    [Parameter] public int EmployeeId { get; set; } = -1;
    [Parameter] public string Title { get; set; } = "Создание отчета";

    [Inject] private NavigationManager _navManager { get; set; }
    [Inject] private MessageService _messageService { get; set; }
    [Inject] private ReportService _reportService { get; set; }

    private Form<EmployeeDto> FormRef { get; set; }
    private EmployeeDto Model { get; set; } = new();

    private DateTime[] dateRange = new DateTime[] { DateTime.Now, DateTime.Now.AddDays(7) };
    private bool isDownloading = false;
    private string? selectedType { get; set; } = "all";
    private bool includeCast { get; set; } = false;

    private async Task GetReportUrl()
    {
        var reportType = selectedType == "all" ? null : selectedType;

        var url = _reportService.GetReportUrl(
            dateRange[0],
            dateRange[1],
            reportType,
            includeCast,
            EmployeeId > 0 ? EmployeeId : null
        );

        _navManager.NavigateTo(url, true);
    }

    private async Task HandleOk()
    {

        isDownloading = true;
        StateHasChanged();

        try
        {
            await GetReportUrl();
            _messageService.Success("Генерация отчета началась. Дожидайтесь скачивания.");
            Visible = false;
            await VisibleChanged.InvokeAsync(false);
        }
        catch (Exception ex)
        {
            _messageService.Error($"Ошибка: {ex.Message}");
        }
        finally
        {
            isDownloading = false;
            StateHasChanged();
        }
    }

    private void OnFinishFailed(EditContext editContext)
    {
        foreach (var error in editContext.GetValidationMessages())
        {
            _messageService.Error(error);
        }
    }

    private async Task HandleCancel()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
        ResetForm();
    }

    private void ResetForm()
    {
        dateRange = new DateTime[] { DateTime.Now, DateTime.Now.AddDays(7) };
        selectedType = null;
        Model = new EmployeeDto();
        FormRef?.Reset();
        StateHasChanged();
    }
}