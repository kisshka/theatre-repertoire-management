@using AntDesign
@using Microsoft.AspNetCore.Components.Forms
@using TheatreManagement.Client.Helpers.SelectItems
@using TheatreManagement.Shared.DTOs

<Modal Visible="@Visible"
OkButtonProps="@(new ButtonProps { Disabled = Submitting })"
Title="Создание отчета"
OnOk="HandleOk"
OnCancel="HandleCancel"
ConfirmLoading="Submitting"
MaskClosable="@false">

    <Form Model="@Model"
    OnFinishFailed="@OnFinishFailed"
    OnFinish="@OnFinish"
    @ref="@FormRef">


        <p>Даты проведения</p>
        <FormItem>
            <RangePicker TValue="DateTime[]"
            ShowTime="false"
            AllowClear="false"
            ChangeOnClose="true"
            MinDate="@(new DateTime(2026, 1, 1))"
            MaxDate="@(new DateTime(3000, 12, 31))"
            @bind-Value="@dateRange" />
        </FormItem>

        <p>Даты проведения</p>
        <FormItem>
            <Select Mode="SelectMode.Default"
            DataSource="@postTypes"
            @bind-Value="@selectedPost"
            LabelName="Name"
            ValueName="Value"
            Placeholder="Выберите должность">
            </Select>
        </FormItem>

    </Form>
</Modal>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }
    [Parameter] public int EmployeeId { get; set; } = -1;

    [Inject] private EmployeeService employeeService { get; set; }

    private Form<EmployeeDto> FormRef { get; set; }
    private EmployeeDto Model { get; set; } = new();

    private DateTime[] dateRange = new DateTime[2];

    private bool Submitting { get; set; } = false;
    private string selectedPost { get; set; } = "";


    private List<SelectItem<string>> postTypes = new()
    {
        new SelectItem<string> { Name = "Актер", Value = "Актер" },
        new SelectItem<string> { Name = "Технический сотрудник", Value = "Технический сотрудник" }
    };


    private async Task OnFinish(EditContext editContext)
    {
        if (Submitting) return;

        Submitting = true;
        StateHasChanged();

        try
        {
            Model.Post = selectedPost;

            await employeeService.CreateEmployeeAsync(Model);

            Visible = false;
            await VisibleChanged.InvokeAsync(false);
            await OnSuccess.InvokeAsync();

            ResetForm();
        }
        catch (Exception ex)
        {
            StateHasChanged();
        }
        finally
        {
            Submitting = false;
            StateHasChanged();
        }
    }

    private void OnFinishFailed(EditContext editContext)
    {
        Console.WriteLine($"Failed");
    }

    private async Task HandleOk()
    {
        if (FormRef != null)
        {
            FormRef.Submit();
        }
    }

    private async Task HandleCancel()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
        ResetForm();
    }


    private void ResetForm()
    {
        Model = new EmployeeDto();
        FormRef?.Reset();
        StateHasChanged();
    }
}