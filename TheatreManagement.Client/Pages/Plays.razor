@page "/plays"

<PageTitle>Список спектаклей</PageTitle>

<PageHeader>
        <PageHeaderTitle>Список спектаклей</PageHeaderTitle>
        <PageHeaderExtra>
            <Button Type="ButtonType.Primary">Архив
            <Icon Type="@IconType.Outline.Right" />
            </Button>
        </PageHeaderExtra>
    </PageHeader>

<div class="table-page-header">
    <Button Type="ButtonType.Primary" OnClick="ShowModalWithService">
        <Icon Type="@IconType.Outline.Plus" />
    </Button>


   <Search Placeholder="Введите название представления"  EnterButton="true"/>
    <Button Type="ButtonType.Default">
        <Icon Type="@IconType.Fill.Filter" />
    </Button>
</div>

<Table TItem="Data" DataSource="@data" PageSize="10">
    @foreach (var column in columns)
    {
        <Column TData="object" DataIndex="@column"></Column>
    }
</Table>

@inject ModalService ModalService;
@inject PlayService playService;
@code {
    public string error = "";
    bool _visible = false;
    bool _submitting = false;
    private Form<PlayDTO> _form;
    private PlayDTO model = new();

    private void ShowModalWithService()
    {
        ModalRef modalRef = default;
        modalRef = ModalService.CreateModal(new()
            {
                Title = "Добавление представления",
                Content = FormTemplate(),

                OnOk = async e =>
                {
                    modalRef?.SetConfirmLoading(true);
                    await Task.Delay(1000);
                    if (!_form.Validate())
                    {
                        modalRef?.SetConfirmLoading(false);
                        return;
                    }

                    _form.Submit();

                    await playService.CreatePlayAsync(model);

                    await modalRef.CloseAsync();

                    _form.Reset();
                },

                OnCancel = async e =>
                {
                    if (!_form.IsModified || await ModalService.ConfirmAsync(new() { Content = "Вы уверены, что не хотите сохранить изменения?" }))
                    {
                        await modalRef.CloseAsync();
                        _form.Reset();
                    }
                },
            });
    }

    private void OnFinish(EditContext editContext)
    {
        _submitting = false;
        _visible = false;
    }

    private void OnFinishFailed(EditContext editContext)
    {
        Console.WriteLine($"Failed:{JsonSerializer.Serialize(model)}");
    }

    RenderFragment FormTemplate()
    {
        return
    @<Form Model="@model"
                   OnFinish="OnFinish"
                   OnFinishFailed="OnFinishFailed"
                   @ref="@_form">

        <div>
            @if(error.Length > 0)
        {
            <Alert Type="AlertType.Error"
                   Message="@error"
                   Banner />
        }
        </div>


        <FormItem Label="Введите название">
            <Input @bind-Value="@context.Name" />
        </FormItem>
        <FormItem Label="Введите продолжительность">
            <Input @bind-Value="@context.Duration" />
        </FormItem>
        <FormItem Label="Введите возрастной рейтинг">
            <Input @bind-Value="@context.AgeCategory" />
        </FormItem>
    </Form>
    ;
    }

    //Заполение таблицы временными данными

    string[] columns = { "Name", "Duration", "Raiting"};

    Data[] data = new Data[100];

    protected override void OnInitialized()
    {
        for (int i = 0; i < 100; i++)
        {
            data[i] = new Data()
            {
                Key = i.ToString(),
                Name = $"Сказка о рыбаке и рыбке{i}",
                Duration = 120,
                Raiting = 12,
            };
        }
    }
   List<Data> options = new List<Data>();
    public class Data
    {
        [DisplayName("Key")]
        public string? Key { get; set; }

        [DisplayName("Название")]
        public string? Name { get; set; }

        [DisplayName("Продолжительность")]
        public int Duration { get; set; }

        [DisplayName("Рейтинг")]
        public int Raiting { get; set; }
    }
}
