@using AntDesign
@using Microsoft.AspNetCore.Components.Forms
@using TheatreManagement.Shared.DTOs
@using TheatreManagement.Shared.DTOs.Events

@* // ПЕРВОЕ МОДАЛЬНОЕ ОКНО *@
<Modal Visible="@Visible"
Title="Изменение мероприятия"
OnOk="HandleOk"
OnCancel="HandleCancel"
ConfirmLoading="Submitting"
MaskClosable="@false">

    <Form Model="@Model" @ref="@FormRef">

        <FormItem Label="Тип мероприятия" Required>
            <Select Mode="SelectMode.Default"
            DataSource="@eventTypes"
            @bind-Value="@selectedEventType"
            LabelName="Name"
            ValueName="Value"
            Placeholder="Выберите тип мероприятия"
            Disabled="@isDisabled"
            onchange="@((string value) => OnEventTypeChanged(value))">
            </Select>
        </FormItem>

        <FormItem Label="Дата и время начала" Required>
            <TimePicker @bind-Value="@startTime"
            AllowClear="false"
            ChangeOnClose="true"
            Format="HH:mm" />
        </FormItem>

        <FormItem Label="Дата и время окончания" Required>
            <TimePicker @bind-Value="@endTime"
            AllowClear="false"
            ChangeOnClose="true"
            Format="HH:mm" />
        </FormItem>

        <!-- Поля для Стационара -->
        @if (selectedEventType == "stationar")
        {
            <Divider>Стационар</Divider>

            <FormItem Label="Зал" Required>
                <Select Mode="SelectMode.Default"
                DataSource="@hallTypes"
                @bind-Value="@selectedHall"
                LabelName="Name"
                ValueName="Value"
                Placeholder="Выберите зал">
                </Select>
            </FormItem>

            <FormItem Label="Тип выступления" Required>
                <Select Mode="SelectMode.Default"
                DataSource="@performanceTypes"
                @bind-Value="@selectedPerformanceType"
                LabelName="Name"
                ValueName="Value"
                Placeholder="Выберите тип выступления">
                </Select>
            </FormItem>
        }

        <!-- Поля для Гастролей -->
        @if (selectedEventType == "tour")
        {
            <Divider>Гастроли</Divider>

            <FormItem Label="Страна" Required>
                <Input @bind-Value="@Model.Tour.Country" />
            </FormItem>

            <FormItem Label="Город/Регион" Required>
                <Input @bind-Value="@Model.Tour.Area" />
            </FormItem>
        }

        <!-- Поля для Выезда -->
        @if (selectedEventType == "visit")
        {
            <Divider>Учреждение</Divider>
            <FormItem Label="Название" Required>
                <Input @bind-Value="@Model.Institution.Name" />
            </FormItem>
            <FormItem Label="Город" Required>
                <Input @bind-Value="@Model.Institution.Town" />
            </FormItem>
            <FormItem Label="Улица" Required>
                <Input @bind-Value="@Model.Institution.Street" />
            </FormItem>
            <FormItem Label="Дом" Required>
                <Input @bind-Value="@Model.Institution.House" />
            </FormItem>
        }

        <!-- Спектакли -->
        <Divider>Спектакли</Divider>

        @for (int i = 0; i < Model.PlayEvents.Count; i++)
        {
            var index = i;
            <div style="border: 1px solid #d9d9d9; border-radius: 4px; padding: 12px; margin-bottom: 12px;">
                <Button Danger OnClick="() => RemovePlayEvent(index)">
                    Удалить
                </Button>
                <Button Type="ButtonType.Primary"
                OnClick="() => OpenRolesModal(index)">
                    Состав
                </Button>

                <FormItem Label="Спектакль">
                    <Select Mode="SelectMode.Default"
                    DataSource="@availablePlays"
                    @bind-Value="@Model.PlayEvents[index].PlayId"
                    LabelName="@nameof(PlayDto.Name)"
                    ValueName="@nameof(PlayDto.PlayId)" />
                </FormItem>

                @if (Model.PlayEvents[index].RoleDisplays.Any())
                {
                    <div>Назначенные роли:</div>
                    @foreach (var roleDisplay in Model.PlayEvents[index].RoleDisplays)
                    {
                        <div style="font-size: 12px; margin-bottom: 4px;">
                            <b>@roleDisplay.RoleName:</b> @roleDisplay.EmployeeNames
                        </div>
                    }
                }

            </div>
        }

        <Button Type="ButtonType.Dashed" OnClick="AddPlayEvent" Block>
            + Добавить спектакль
        </Button>

    </Form>
</Modal>

@* ВТОРОЕ МОДАЛЬНОЕ ОКНО *@

<Modal Visible="@rolesModalVisible"
OnOk="SaveRoles"
OnCancel="CancelRoles"
Title="Назначение ролей">
    <div>
        <b>Спектакль:</b> @currentPlayName
    </div>

    @* Выбор готового каста *@
    <Select TItem="CastDto"
    TItemValue="int"
    DataSource="@currentPlayCasts"
    @bind-Value="@selectedCastId"
    LabelName="@nameof(CastDto.Name)"
    ValueName="@nameof(CastDto.CastId)"
    OnSelectedItemChanged="@OnSelectedItemChangedHandler">
    </Select>

    <Form Model="@EmployeeRolesModel" @ref="@EmployeeRolesFormRef">

        @* Динамическое добавление сотрудников на роли *@
        <Divider>Актеры</Divider>

        @foreach (var role in play.RoleDtos.Where(r => r.RoleType == "Актерская"))
        {
            <div style="margin-bottom: 20px; border: 1px solid #ddd; padding: 10px; border-radius: 4px;">
                <b>@role.Name</b>

                @for (int i = 0; i < GetTempAssignmentsCount(role.RoleInPlayId); i++)
                {
                    var roleId = role.RoleInPlayId;
                    var index = i;
                    <div style="display: flex; gap: 10px; margin-top: 10px;">
                        <Select Mode="SelectMode.Default"
                        DataSource="@actors"
                        Value="@GetTempAssignmentEmployeeId(roleId, index)"
                        ValueChanged="@((int value) => SetTempAssignmentEmployeeId(roleId, index, value))"
                        LabelName="@nameof(EmployeeDto.Surname)"
                        ValueName="@nameof(EmployeeDto.EmployeeId)"
                        Style="flex: 1" />

                        <Button Danger OnClick="() => RemoveTempAssignment(roleId, index)">
                            <Icon Type="@IconType.Outline.Delete" />
                        </Button>
                    </div>
                }

                <Button Type="ButtonType.Primary"
                OnClick="() => AddTempAssignment(role.RoleInPlayId)"
                Style="margin-top: 10px">
                    + Добавить актера
                </Button>
            </div>
        }

        <Divider>Технический состав</Divider>

        @foreach (var role in play.RoleDtos.Where(r => r.RoleType == "Техническая"))
        {
            <div style="margin-bottom: 20px; border: 1px solid #ddd; padding: 10px; border-radius: 4px;">
                <b>@role.Name</b>

                @for (int i = 0; i < GetTempAssignmentsCount(role.RoleInPlayId); i++)
                {
                    var roleId = role.RoleInPlayId;
                    var index = i;
                    <div style="display: flex; gap: 10px; margin-top: 10px;">
                        <Select Mode="SelectMode.Default"
                        DataSource="@technics"
                        Value="@GetTempAssignmentEmployeeId(roleId, index)"
                        ValueChanged="@((int value) => SetTempAssignmentEmployeeId(roleId, index, value))"
                        LabelName="@nameof(EmployeeDto.Surname)"
                        ValueName="@nameof(EmployeeDto.EmployeeId)"
                        Style="flex: 1" />

                        <Button Danger OnClick="() => RemoveTempAssignment(roleId, index)">
                            <Icon Type="@IconType.Outline.Delete" />
                        </Button>
                    </div>
                }

                <Button Type="ButtonType.Primary"
                OnClick="() => AddTempAssignment(role.RoleInPlayId)"
                Style="margin-top: 10px">
                    + Добавить сотрудника
                </Button>
            </div>
        }
    </Form>

</Modal>


@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }
    [Parameter] public DateTime EventDate { get; set; }
    [Parameter] public int EventId { get; set; }

    [Inject] private AuthenticationStateProvider provider { get; set; }
    [Inject] private PlayService playService { get; set; }
    [Inject] private EmployeeService employeeService { get; set; }
    [Inject] private EventService eventService { get; set; }
    [Inject] private IMessageService messageService { get; set; }

    private Form<EventPostModel> FormRef { get; set; }
    private EventPostModel Model { get; set; } = new();
    private EventGetModel EditedEvent { get; set; } = new();

    private string selectedEventType = "stationar";
    private List<PlayDto> availablePlays = new();
    private bool Submitting { get; set; } = false;

    private DateTime? startTime;
    private DateTime? endTime;

    // Для стационара
    private string selectedHall = "";
    private string selectedPerformanceType = "";

    // Списки для стационара
    private List<SelectItem<string>> hallTypes = new()
    {
        new SelectItem<string> { Name = "Большой зал", Value = "Большой зал" },
        new SelectItem<string> { Name = "Малый зал", Value = "Малый зал" }
    };

    private List<SelectItem<string>> performanceTypes = new()
    {
        new SelectItem<string> { Name = "Репетиция", Value = "Репетиция" },
        new SelectItem<string> { Name = "Выступление", Value = "Выступление" }
    };

    public List<SelectItem<string>> eventTypes = new()
    {
        new SelectItem<string> { Name = "Стационар", Value = "stationar" },
        new SelectItem<string> { Name = "Гастроли", Value = "tour" },
        new SelectItem<string> { Name = "Выезд", Value = "visit" }
    };

    // Метод для объединения даты и времени
    private DateTime? CombineDateAndTime(DateTime date, DateTime? time)
    {
        if (time == null) return null;
        return new DateTime(date.Year, date.Month, date.Day, time.Value.Hour, time.Value.Minute, time.Value.Second);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Visible)
        {
            await LoadData();
            await LoadUserData();
            await LoadPlays();
        }
    }

    private async Task OnEventTypeChanged(string selectedType)
    {
        selectedEventType = selectedType;

        // if (selectedType != "stationar")
        //     Model.Stationar = new StationarDto();

        // if (selectedType != "tour")
        //     Model.Tour = new TourDto();

        // if (selectedType != "visit")
        //     Model.Institution = new InstitutionDto();

        StateHasChanged();
    }

    // Подгрузка данных для редактирования
    private async Task LoadData()
    {
        Model = await eventService.GetEventForEditAsync(EventId);
        selectedEventType = Model.Type;
        startTime = Model.StartTime;
        endTime = Model.EndTime;

        Model.Stationar ??= new StationarDto();
        Model.Tour ??= new TourDto();
        Model.Institution ??= new InstitutionDto();

        if (Model.Type == "stationar")
        {
            selectedHall = Model.Stationar.Hall;
            selectedPerformanceType = Model.Stationar.Type;
        }
    }

    private async Task LoadPlays()
    {
        availablePlays = await playService.GetPlaysAsync();
    }

    private void AddPlayEvent()
    {
        Model.PlayEvents.Add(new PlayEventDto());
        StateHasChanged();
    }

    private void RemovePlayEvent(int index)
    {
        Model.PlayEvents.RemoveAt(index);
        StateHasChanged();
    }

    private bool ValidateForm()
    {
        if (startTime == null)
        {
            messageService.Error("Укажите время начала");
            return false;
        }
        if (endTime == null)
        {
            messageService.Error("Укажите время окончания");
            return false;
        }
        if (selectedEventType == "stationar")
        {
            if (string.IsNullOrWhiteSpace(selectedHall))
            {
                messageService.Error("Выберите зал");
                return false;
            }
            if (string.IsNullOrWhiteSpace(selectedPerformanceType))
            {
                messageService.Error("Выберите тип выступления");
                return false;
            }
        }
        if (selectedEventType == "tour")
        {
            if (string.IsNullOrWhiteSpace(Model.Tour?.Country))
            {
                messageService.Error("Введите страну");
                return false;
            }
            if (string.IsNullOrWhiteSpace(Model.Tour?.Area))
            {
                messageService.Error("Введите город/регион");
                return false;
            }
        }
        if (selectedEventType == "visit")
        {
            if (string.IsNullOrWhiteSpace(Model.Institution?.Name))
            {
                messageService.Error("Введите название учреждения");
                return false;
            }
            if (string.IsNullOrWhiteSpace(Model.Institution?.Town))
            {
                messageService.Error("Введите город");
                return false;
            }
            if (string.IsNullOrWhiteSpace(Model.Institution?.Street))
            {
                messageService.Error("Введите улицу");
                return false;
            }
            if (string.IsNullOrWhiteSpace(Model.Institution?.House))
            {
                messageService.Error("Введите номер дома");
                return false;
            }
        }
        if (!Model.PlayEvents.Any())
        {
            messageService.Error("Добавьте хотя бы один спектакль");
            return false;
        }
        foreach (var playEvent in Model.PlayEvents)
        {
            if (playEvent.PlayId == 0)
            {
                messageService.Error("Выберите спектакль");
                return false;
            }
            if (!playEvent.SelectedEmployees.Any())
            {
                messageService.Error("Назначьте состав для спектакля");
                return false;
            }
        }
        return true;
    }

    private async Task HandleOk()
    {
        Console.WriteLine("Начинаем обновление");
        if (Submitting) return;

        // if (!ValidateForm())
        // {
        //     return;
        // }

        StateHasChanged();

        try
        {
            Submitting = true;

            Model.StartTime = CombineDateAndTime(EventDate, startTime);
            Model.EndTime = CombineDateAndTime(EventDate, endTime);
            Model.Type = selectedEventType;

            if (selectedEventType == "stationar")
            {
                Model.Stationar.Hall = selectedHall;
                Model.Stationar.Type = selectedPerformanceType;
            }

            await eventService.UpdateEventAsync(Model);

            messageService.Success("Мероприятие успешно обновлено!");

            Visible = false;
            await VisibleChanged.InvokeAsync(false);
            await OnSuccess.InvokeAsync();
            ResetForm();
        }
        catch (Exception ex)
        {
            messageService.Error($"Ошибка: {ex.Message}");
        }
        finally
        {
            Submitting = false;
            StateHasChanged();
        }
    }

    private async Task HandleCancel()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
        ResetForm();
    }

    private void ResetForm()
    {
        Model = new EventPostModel();
        selectedEventType = "stationar";
        FormRef?.Reset();
        StateHasChanged();
    }

    // ==================== ВТОРОЕ МОДАЛЬНОЕ ОКНО ====================

    private bool rolesModalVisible = false;
    private Form<EmployeeRoleCreateDto> EmployeeRolesFormRef { get; set; }
    private EmployeeRoleCreateDto EmployeeRolesModel { get; set; } = new();

    // Данные для ролей
    private PlayDto play = new();
    private List<EmployeeDto> actors = new();
    private List<EmployeeDto> technics = new();

    // Новая структура - список назначений вместо словаря
    private List<EmployeeRoleSelectDto> tempSelections = new();

    private int currentPlayEventIndex = -1;
    private int currentPlayId = 0;
    private string currentPlayName = "";

    // Переменные для подгрузки сотрудников из каста
    private List<CastDto> currentPlayCasts = new();
    private int selectedCastId;
    private CastWithRolesDto selectedCast = new();

    private void OpenRolesModal(int index)
    {
        currentPlayEventIndex = index;
        currentPlayId = Model.PlayEvents[currentPlayEventIndex].PlayId;

        var selectedPlay = availablePlays.FirstOrDefault(p => p.PlayId == currentPlayId);
        currentPlayName = selectedPlay?.Name ?? "Не выбран";

        selectedCastId = Model.PlayEvents[currentPlayEventIndex].CastId;
        LoadPlayData(currentPlayId);

        rolesModalVisible = true;
        StateHasChanged();
    }

    private async void LoadPlayData(int playId)
    {
        if (playId > 0)
        {
            play = await playService.GetPlayAsync(playId);
            actors = await employeeService.GetActorsAsync();
            technics = await employeeService.GetTechnicsAsync();

            currentPlayCasts = await playService.GetCastsAsync(playId);

            // Загружаем сохраненные роли
            LoadSavedRolesIntoTempAssignments();

            StateHasChanged();
        }
    }

    private void LoadSavedRolesIntoTempAssignments()
    {
        tempSelections.Clear();

        if (currentPlayEventIndex >= 0)
        {
            var playEvent = Model.PlayEvents[currentPlayEventIndex];

            if (playEvent.SelectedEmployees != null && playEvent.SelectedEmployees.Any())
            {
                foreach (var role in playEvent.SelectedEmployees)
                {
                    tempSelections.Add(new EmployeeRoleSelectDto
                        {
                            EmployeeId = role.EmployeeId,
                            RoleInPlayId = role.RoleInPlayId,
                            RoleName = GetRoleName(role.RoleInPlayId),
                            EmployeeFullName = GetEmployeeFullName(role.EmployeeId)
                        });
                }
            }
        }
    }

    private async Task OnSelectedItemChangedHandler()
    {
        selectedCast = await playService.GetCastAsync(selectedCastId);
        tempSelections.Clear();

        foreach (var role in selectedCast.Roles)
        {
            foreach (var employee in role.Employees)
            {
                tempSelections.Add(new EmployeeRoleSelectDto
                    {
                        EmployeeId = employee.EmployeeId,
                        RoleInPlayId = role.RoleInPlayId,
                        RoleName = GetRoleName(role.RoleInPlayId),
                        EmployeeFullName = $"{employee.Surname} {employee.Name}"
                    });
            }
        }
        StateHasChanged();
    }

    private void SaveRoles()
    {
        if (currentPlayEventIndex >= 0)
        {
            var playEvent = Model.PlayEvents[currentPlayEventIndex];

            playEvent.SelectedEmployees = tempSelections.Select(a => new EmployeeRoleSelectDto
                {
                    EmployeeId = a.EmployeeId,
                    RoleInPlayId = a.RoleInPlayId,
                    RoleName = a.RoleName,
                    EmployeeFullName = a.EmployeeFullName
                }).ToList();

            playEvent.CastId = selectedCastId;
        }

        rolesModalVisible = false;
        StateHasChanged();

        messageService.Success("Роли сохранены");
        ResetRolesModalState();
    }

    private void CancelRoles()
    {
        rolesModalVisible = false;
        StateHasChanged();
        ResetRolesModalState();
    }

    private void ResetRolesModalState()
    {
        selectedCastId = 0;
        selectedCast = new CastWithRolesDto();
        tempSelections.Clear();
        currentPlayEventIndex = -1;
        currentPlayId = 0;
        currentPlayName = "";
        play = new PlayDto();
        actors = new List<EmployeeDto>();
        technics = new List<EmployeeDto>();
        currentPlayCasts = new List<CastDto>();
        StateHasChanged();
    }

    // Для заполнения сотрудников и ролей
    private string GetEmployeeFullName(int employeeId)
    {
        var employee = actors.FirstOrDefault(a => a.EmployeeId == employeeId) ??
                       technics.FirstOrDefault(t => t.EmployeeId == employeeId);
        return employee != null ? $"{employee.Surname} {employee.Name}" : "";
    }

    private string GetRoleName(int roleId)
    {
        return play.RoleDtos.FirstOrDefault(r => r.RoleInPlayId == roleId)?.Name ?? "";
    }

    // ==================== Вспомогательные методы для tempAssignments ====================

    private int GetTempAssignmentsCount(int roleId)
    {
        return tempSelections.Count(a => a.RoleInPlayId == roleId);
    }

    private int GetTempAssignmentEmployeeId(int roleId, int index)
    {
        var assignments = tempSelections.Where(a => a.RoleInPlayId == roleId).ToList();
        if (index >= 0 && index < assignments.Count)
            return assignments[index].EmployeeId;
        return 0;
    }

    private void SetTempAssignmentEmployeeId(int roleId, int index, int value)
    {
        var assignments = tempSelections.Where(a => a.RoleInPlayId == roleId).ToList();
        if (index >= 0 && index < assignments.Count)
        {
            assignments[index].EmployeeId = value;
            assignments[index].EmployeeFullName = GetEmployeeFullName(value);
        }
        StateHasChanged();
    }

    private void AddTempAssignment(int roleId)
    {
        tempSelections.Add(new EmployeeRoleSelectDto
            {
                EmployeeId = 0,
                RoleInPlayId = roleId,
                RoleName = GetRoleName(roleId),
                EmployeeFullName = ""
            });
        StateHasChanged();
    }

    private void RemoveTempAssignment(int roleId, int index)
    {
        var assignments = tempSelections.Where(a => a.RoleInPlayId == roleId).ToList();
        if (index >= 0 && index < assignments.Count)
        {
            var toRemove = assignments[index];
            tempSelections.Remove(toRemove);
        }
        StateHasChanged();
    }

    private bool isDisabled { get; set; } = false;
    private async Task LoadUserData()
    {
        var authStateProvider = (CustomAuthStateProvider)provider;
        string userRole = await authStateProvider.GetCurrentUserRoleAsync();
        isDisabled = userRole != "MainAdmin";
    }
}