@page "/events"
@page "/"
@using System.Globalization
@using AntDesign
@using TheatreManagement.Shared.DTOs.Events

<PageTitle>Мероприятия</PageTitle>

<Calendar   Value="currentDate"
DateCellRender="DateCellRender"
HeaderRender="CustomHead"
OnSelect="OnDateSelect"
CultureInfo="@CultureInfo.InvariantCulture" />

@inject NavigationManager navManager
@inject EventService eventService

@code {
    private DateTime currentDate = DateTime.Now;
    private List<EventGetModel> allEvents = new();
    private bool isLoading = false;

    class ListData
    {
        public string TimePeriod;
        public string EventType;
        public string content;
        public bool IsCanceled;
    }

    private string GetEventStyleByType(string eventType, bool isCanceled)
    {
        if (isCanceled) return "color: var(--canceled-text); text-decoration: line-through;";

        return eventType switch
        {
            "stationar" => "color: var(--stationar-text);",
            "tour" => "color: var(--tour-text);",
            "visit" => "color: var(--visit-text);",
            _ => "color: #000000;"
        };
    }

    // Загружаем события при смене месяца через Value
    private async Task OnValueChanged(DateTime newDate)
    {
        currentDate = newDate;
        await LoadEventsForMonth(currentDate);
    }

    private async Task LoadEventsForMonth(DateTime date)
    {
        if (isLoading) return;
        isLoading = true;

        try
        {
            // Получаем первый и последний день месяца
            var firstDayOfMonth = new DateTime(date.Year, date.Month, 1);
            var lastDayOfMonth = firstDayOfMonth.AddMonths(1).AddDays(-1);

            var startDate = firstDayOfMonth.AddDays(-14);
            var endDate = lastDayOfMonth.AddDays(14);

            allEvents = await eventService.GetEventsByDateRangeAsync(startDate, endDate);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private List<ListData> GetListData(DateTime value)
    {
        var listData = new List<ListData>();

        var eventsOnDay = allEvents.Where(e =>
        e.StartTime?.Date == value.Date ||
        (e.StartTime?.Date <= value.Date && e.EndTime?.Date >= value.Date));

        foreach (var ev in eventsOnDay)
        {
            string content = "";
            content += ev.Plays.Select(p => p.Name).First();

            string timePeriod = ev.Type == "stationar" ? $"{ev.StationarTimePeriod}" :
            ev.Type == "tour" ? $"{ev.TourTimePeriod}" : $"{ev.VisitTimePeriod}";

            listData.Add(new ListData
                    {
                        EventType = ev.Type,
                        IsCanceled = ev.IsCanceled,
                        content = content,
                        TimePeriod = timePeriod
                    });
        }

        return listData;
    }

    private RenderFragment CustomHead(CalendarHeaderRenderArgs calendarHeaderRenderArgs)
    {
        return @<Template>
            <div class="calendar-header-container">
                <div class="calendar-header">
                    <Button @onclick="PreviousMonth">
                        <Icon class="calendar-icons" Type="@IconType.Outline.Left" />
                    </Button>

                    <DatePicker ValueChanged="OnDatePickerChanged"
                                AllowClear="false" 
                                Value="currentDate"
                                ShowToday="true"
                                TValue="DateTime"
                                Picker="DatePickerType.Month" />

                    <Button @onclick="NextMonth">
                        <Icon class="calendar-icons" Type="@IconType.Outline.Right" />
                    </Button>
                </div>
            </div>
        </Template>;
    }

    private void OnDateSelect(DateTime date)
    {
        var dateString = $"{date.Year:0000}-{date.Month:00}-{date.Day:00}";
        navManager.NavigateTo($"/events/{dateString}");
    }

    private async Task OnDatePickerChanged(DateTime newDate)
    {
        currentDate = newDate;
        await LoadEventsForMonth(currentDate);
        StateHasChanged();
    }
    
    private async Task NextMonth()
    {
        currentDate = currentDate.AddMonths(1);
        await LoadEventsForMonth(currentDate);
        StateHasChanged(); 
    }
    
    private async Task PreviousMonth()
    {
        currentDate = currentDate.AddMonths(-1);
        await LoadEventsForMonth(currentDate);
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadEventsForMonth(currentDate);
    }

    private RenderFragment DateCellRender(DateTime value)
    {
        var listData = GetListData(value);
        return @<Template>
            <ul class="events" style="cursor: pointer; min-height: 60px;">
                @foreach (var data in listData)
                {
                    <li key="@data.content">
                            <span style="font-weight:inherit;">@data.TimePeriod</span>
                            <span style="@GetEventStyleByType(data.EventType, data.IsCanceled)">
                                @data.content
                            </span>
                    </li>
                }
            </ul>
        </Template>;
    }
}