@page "/employees"
@inject HttpClient Http

<PageTitle>Список сотрудников</PageTitle>

<PageHeader>
        <PageHeaderTitle>Список сотрудников</PageHeaderTitle>
        <PageHeaderExtra>
            <Button Type="ButtonType.Primary">Архив
            <Icon Type="@IconType.Outline.Right" />
            </Button>
        </PageHeaderExtra>
    </PageHeader>

<div class="table-page-header">
    <Button Type="ButtonType.Primary">
        <Icon Type="@IconType.Outline.Plus" />
    </Button>

   <Search Placeholder="Введите ФИО сотрудника"  EnterButton="true"/>

    <Button Type="ButtonType.Default">
        <Icon Type="@IconType.Fill.Filter" />
    </Button>
</div>

<Table TItem="Data" DataSource="@data" PageSize="10">
    @foreach (var column in columns)
    {
        <Column TData="object" DataIndex="@column"></Column>
    }
  <Column Title="Присутствует" TData="bool">
    <CellRender Context="cell">
            @if (context.IsPresent)
            {
                <Icon Type="@IconType.Fill.CheckCircle" Style="color: #52c41a; font-size: 18px;" />
            }
            else
            {
                <Icon Type="@IconType.Fill.CloseCircle" Style="color: #ff4d4f; font-size: 18px;" />
            }
    </CellRender>
  </Column>
</Table>

@code {
    string[] columns = { "FullName", "Post"};

    Data[] data = new Data[100];

    protected override void OnInitialized()
    {
        for (int i = 0; i < 100; i++)
        {
            data[i] = new Data()
            {
                Key = i.ToString(),
                FullName = $"Иванов Иван Иванович{i}",
                Post = "Актер",
                IsPresent = true,
            };
            data[i+1] = new Data()
            {
                Key = i.ToString(),
                FullName = $"Иванов Иван Иванович{i}",
                Post = "Актер",
                IsPresent = false,
            };
        i++;
        }
    }
   List<Data> options = new List<Data>();
    public class Data
    {
        [DisplayName("Key")]
        public string? Key { get; set; }

        [DisplayName("ФИО")]
        public string? FullName { get; set; }

        [DisplayName("Должность")]
        public string? Post { get; set; }

        [DisplayName("Присутствует")]
        public bool IsPresent { get; set; }
    }
}


