@using AntDesign
@using Microsoft.AspNetCore.Components.Forms
@using TheatreManagement.Client.Helpers.SelectItems
@using TheatreManagement.Shared.DTOs

<Modal Visible="@Visible"
       OkButtonProps="@(new ButtonProps { Disabled = Submitting })"
       Title="Редактирование представления"
       OnOk="HandleOk"
       OnCancel="HandleCancel"
       ConfirmLoading="Submitting"
       MaskClosable="@false">

    <Form Model="@Model"
          OnFinishFailed="@OnFinishFailed"
          OnFinish="@OnFinish"
          @ref="@FormRef">

        <FormItem Label="Введите название">
            <Input @bind-Value="@context.Name" />
        </FormItem>
        <FormItem Label="Введите продолжительность">
            <Input @bind-Value="@context.Duration" />
        </FormItem>
        <FormItem Label="Тип сцены" Required>
            <Select Mode="SelectMode.Default"
                    DataSource="@sceneTypes"
                    @bind-Value="@selectedSceneTypeId"
                    LabelName="Name"
                    ValueName="Id"
                    Placeholder="Выберите тип сцены">
            </Select>
        </FormItem>
        <FormItem Label="Введите возрастной рейтинг">
            <Input @bind-Value="@context.AgeCategory" />
        </FormItem>
        <FormItem Label="Статус" Required>
            <Select Mode="SelectMode.Default"
                    DataSource="@Status"
                    @bind-Value="@selectedStatus"
                    LabelName="Name"
                    ValueName="Value">
            </Select>
        </FormItem>

        @if (error.Length > 0)
        {
            <Alert Type="AlertType.Error"
                   Message="@error"
                   Banner />
        }

        @* Актерские роли *@
        <Divider Orientation="DividerOrientation.Left">Актерские роли</Divider>

        <Button Type="ButtonType.Primary"
                OnClick="@AddActorRole"
                Icon="@IconType.Outline.Plus">
            Добавить роль
        </Button>

        @for (int i = 0; i < ActorRoles.Count; i++)
        {
            var currentIndex = i;
            <div class="dinamic-fields">
                <FormItem Required>
                    <Input @bind-Value="@ActorRoles[currentIndex].Name"
                           Placeholder="Введите название роли" />
                </FormItem>
                <Button Danger Class="danger-button"
                        OnClick="@(() => RemoveActorRole(currentIndex))"
                        Disabled="@(ActorRoles.Count == 1 || ActorRoles[currentIndex].IsUsed)">
                    <Icon Type="@IconType.Outline.Delete" />
                </Button>
            </div>
        }

        @* Технические роли *@
        <Divider Orientation="DividerOrientation.Left">Технические роли</Divider>

        <Button Type="ButtonType.Primary"
                OnClick="@AddTechnicRole"
                Icon="@IconType.Outline.Plus">
            Добавить роль
        </Button>

        @for (int i = 0; i < TechnicRoles.Count; i++)
        {
            var currentIndex = i;
            <div class="dinamic-fields">
                <FormItem Required>
                    <Input @bind-Value="@TechnicRoles[currentIndex].Name"
                           Placeholder="Введите название роли" />
                </FormItem>
                <Button Danger Class="danger-button"
                        OnClick="@(() => RemoveTechnicRole(currentIndex))"
                        Disabled="@(TechnicRoles.Count == 1 || TechnicRoles[currentIndex].IsUsed)">
                    <Icon Type="@IconType.Outline.Delete" />
                </Button>
            </div>
        }

    </Form>
</Modal>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }
    [Parameter] public int PlayId { get; set; }

    [Inject] private PlayService playService { get; set; }

    private Form<PlayDto> FormRef { get; set; }
    private PlayDto Model { get; set; } = new();

    private List<RoleDto> ActorRoles { get; set; } = new();
    private List<RoleDto> TechnicRoles { get; set; } = new();

    private bool Submitting { get; set; } = false;
    private bool selectedStatus = true;
    private int selectedSceneTypeId;

    private List<SelectItem<bool>> Status = new()
    {
        new SelectItem<bool> { Name = "Активен", Value = true },
        new SelectItem<bool> { Name = "Неактивен", Value = false }
    };

    // Для типа сцены
    private List<SceneTypeDto> sceneTypes = new();
    private string error = "";

    protected override async Task OnParametersSetAsync()
    {
        if (Visible)
        {
            await LoadSceneTypes();
            await LoadData();
        }
    }

    private async Task LoadSceneTypes()
    {
        try
        {
            sceneTypes = await playService.GetAllSceneTypeAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки типов сцен: {ex.Message}");
        }
    }

    private async Task LoadData()
    {
        try
        {
            Model = await playService.GetPlayAsync(PlayId);
            selectedStatus = Model.IsActive;
            selectedSceneTypeId = Model.SceneTypeId;

            ActorRoles = Model.RoleDtos.Where(r => r.RoleType == "Актерская").ToList();
            TechnicRoles = Model.RoleDtos.Where(r => r.RoleType == "Техническая").ToList();

            if (ActorRoles.Count == 0)
            {
                ActorRoles = new List<RoleDto> { new RoleDto { Name = "", RoleType = "Актерская" } };
            }
            if (TechnicRoles.Count == 0)
            {
                TechnicRoles = new List<RoleDto> { new RoleDto { Name = "", RoleType = "Техническая" } };
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task OnFinish(EditContext editContext)
    {
        if (Submitting) return;

        Submitting = true;
        StateHasChanged();

        try
        {
            error = "";

            if (selectedSceneTypeId == 0)
            {
                error = "Выберите тип сцены";
                return;
            }

            Model.IsActive = selectedStatus;
            Model.SceneTypeId = selectedSceneTypeId;
            Model.RoleDtos.Clear();

            foreach (var role in ActorRoles)
            {
                if (!string.IsNullOrWhiteSpace(role.Name))
                {
                    Model.RoleDtos.Add(new RoleDto
                        {
                            RoleInPlayId = role.RoleInPlayId,
                            Name = role.Name,
                            RoleType = "Актерская",
                            IsUsed = role.IsUsed
                        });
                }
            }

            foreach (var role in TechnicRoles)
            {
                if (!string.IsNullOrWhiteSpace(role.Name))
                {
                    Model.RoleDtos.Add(new RoleDto
                        {
                            RoleInPlayId = role.RoleInPlayId,
                            Name = role.Name,
                            RoleType = "Техническая",
                            IsUsed = role.IsUsed
                        });
                }
            }

            if (Model.RoleDtos.Count == 0)
            {
                error = "Добавьте хотя бы одну роль";
                return;
            }

            await playService.UpdatePlayAsync(Model);

            Visible = false;
            await VisibleChanged.InvokeAsync(false);
            await OnSuccess.InvokeAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            StateHasChanged();
        }
        finally
        {
            Submitting = false;
            StateHasChanged();
        }
    }

    private void OnFinishFailed(EditContext editContext)
    {
        Console.WriteLine($"Failed");
    }

    private async Task HandleOk()
    {
        if (FormRef != null)
        {
            FormRef.Submit();
        }
    }

    private async Task HandleCancel()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
    }

    private void AddActorRole()
    {
        ActorRoles.Add(new RoleDto { Name = "", RoleType = "Актерская" });
        StateHasChanged();
    }

    private void RemoveActorRole(int index)
    {
        if (ActorRoles.Count > 1 && index >= 0 && index < ActorRoles.Count)
        {
            ActorRoles.RemoveAt(index);
            StateHasChanged();
        }
    }

    private void AddTechnicRole()
    {
        TechnicRoles.Add(new RoleDto { Name = "", RoleType = "Техническая" });
        StateHasChanged();
    }

    private void RemoveTechnicRole(int index)
    {
        if (TechnicRoles.Count > 1 && index >= 0 && index < TechnicRoles.Count)
        {
            TechnicRoles.RemoveAt(index);
            StateHasChanged();
        }
    }
}