@page "/plays/{id:int}"

<PageTitle>Информация о спектакле</PageTitle>

<PageHeader>

    <PageHeaderTitle>Информация о спектакле</PageHeaderTitle>
    <PageHeaderExtra>

        <Button Type="ButtonType.Primary"
        OnClick="@GoBack">
            Назад
            <Icon Type="@IconType.Outline.Left" />
        </Button>
        <Button Type="ButtonType.Primary"
        OnClick="@GoToCasts">
            Составы
            <Icon Type="@IconType.Outline.Right" />
        </Button>

    </PageHeaderExtra>
</PageHeader>



<Card Title=@play.Name>
    <CardAction>
        <Button Type="ButtonType.Default" OnClick="@(() => editModalVisible = true)">
            <Icon Type="@IconType.Outline.Edit" />
        </Button>
        <Button Danger>
            <Icon Type="@IconType.Outline.Delete" OnClick="@SoftDelete" />
        </Button>
    </CardAction>
    <CardGrid Style="width:33%;text-align:center" Hoverable="false">
        Длительность: @play.Duration
    </CardGrid>
    <CardGrid Style="width:33%;text-align:center" Hoverable="false">
        Рейтинг: @play.AgeCategory+
    </CardGrid>
    <CardGrid Style="width:33%;text-align:center" Hoverable="false">
        Статус: @play.IsActive
    </CardGrid>

    <CardGrid Style="width:50%;text-align:center" Hoverable="false">

        <AntList Bordered DataSource="@actorRoles">
            <Header>Актерские роли</Header>
            <ChildContent Context="item">
                <ListItem>
                    @item.Name
                </ListItem>
            </ChildContent>
        </AntList>

    </CardGrid>
    <CardGrid Style="width:50%;text-align:center" Hoverable="false">
        <AntList Bordered DataSource="@technicRoles">
            <Header>Технические роли</Header>
            <ChildContent Context="item">
                <ListItem>
                    @item.Name
                </ListItem>
            </ChildContent>
        </AntList>
    </CardGrid>

</Card>

<EditModal @bind-Visible="@editModalVisible"
PlayId="Id"
OnSuccess="@OnPlayAdded" />

@inject PlayService playService
@inject NavigationManager navManager
@code {
    [Parameter] public int Id { get; set; }

    private PlayDto play = new();
    private List<RoleDto> actorRoles = new();
    private List<RoleDto> technicRoles = new();

    private bool editModalVisible = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task OnPlayAdded()
    {
        await LoadData();
    }

    private async Task SoftDelete()
    {
        await playService.SoftDeletePlayAsync(Id);
        navManager.NavigateTo("/plays");
    }

    private async Task LoadData()
    {
        play = await playService.GetPlayAsync(Id);

        actorRoles = play.RoleDtos.Where(r => r.RoleType == "Актерская").ToList();
        technicRoles = play.RoleDtos.Where(r => r.RoleType == "Техническая").ToList();
    }

    private void GoBack()
    {
        navManager.NavigateTo("/plays");
    }
    private void GoToCasts()
    {
        navManager.NavigateTo($"/plays/{play.PlayId}/casts");
    }
}
