@using AntDesign
@using Microsoft.AspNetCore.Components.Forms
@using TheatreManagement.Client.Helpers.SelectItems
@using TheatreManagement.Shared.DTOs

<Modal Visible="@Visible"
OkButtonProps="@(new ButtonProps { Disabled = Submitting })"
Title="Редактирование сотрудника"
OnOk="HandleOk"
OnCancel="HandleCancel"
ConfirmLoading="Submitting"
MaskClosable="@false">

    <Form Model="@Model"
    OnFinishFailed="@OnFinishFailed"
    OnFinish="@OnFinish"
    @ref="@FormRef">

        <FormItem Label="Введите фамилию" Required>
            <Input @bind-Value="@context.Surname" />
        </FormItem>
        <FormItem Label="Введите имя" Required>
            <Input @bind-Value="@context.Name" />
        </FormItem>
        <FormItem Label="Введите отчество">
            <Input @bind-Value="@context.FatherName" />
        </FormItem>
        <FormItem Label="Статус" Required>
            <Select Mode="SelectMode.Default"
            DataSource="@Status"
            @bind-Value="@selectedStatus"
            LabelName="Name"
            ValueName="Value">
            </Select>
        </FormItem>
        <FormItem Label="Выберите должность" Required>
            <Select Mode="SelectMode.Default"
            DataSource="@postTypes"
            @bind-Value="@selectedPost"
            LabelName="Name"
            ValueName="Value"
            Placeholder="Выберите должность">
            </Select>
        </FormItem>

    </Form>
</Modal>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }
    [Parameter] public int EmployeeId { get; set; }

    [Inject] private EmployeeService employeeService { get; set; }

    private Form<EmployeeDto> FormRef { get; set; }
    private EmployeeDto Model { get; set; } = new();

    private string Error { get; set; } = "";
    private bool Submitting { get; set; } = false;
    private string selectedPost { get; set; } = "";

    private bool selectedStatus = true;
    private List<SelectItem<bool>> Status = new()
    {
        new SelectItem<bool> { Name = "Активен", Value = true },
        new SelectItem<bool> { Name = "Неактивен", Value = false }
    };
    // Список должностей
    private List<SelectItem<string>> postTypes = new()
    {
        new SelectItem<string> { Name = "Актер", Value = "Актер" },
        new SelectItem<string> { Name = "Технический сотрудник", Value = "Технический сотрудник" }
    };

    protected override async Task OnParametersSetAsync()
    {
        if (Visible)
        {
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        var employee = await employeeService.GetEmployeeAsync(EmployeeId);

        Model = employee;
        selectedPost = employee.Post;
        selectedStatus = employee.IsActive;

        StateHasChanged();
    }

    private async Task OnFinish(EditContext editContext)
    {
        if (Submitting) return;

        Submitting = true;
        StateHasChanged();

        try
        {
            Model.IsActive = selectedStatus;
            Model.Post = selectedPost;

            await employeeService.UpdateEmployeeAsync(Model);

            Visible = false;
            await VisibleChanged.InvokeAsync(false);
            await OnSuccess.InvokeAsync();

            ResetForm();
        }
        catch (Exception ex)
        {
            Error = ex.Message;
            StateHasChanged();
        }
        finally
        {
            Submitting = false;
            StateHasChanged();
        }
    }

    private void OnFinishFailed(EditContext editContext)
    {
        Console.WriteLine($"Failed");
    }

    private async Task HandleOk()
    {
        if (FormRef != null)
        {
            FormRef.Submit();
        }
    }

    private async Task HandleCancel()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
        ResetForm();
    }

    private void ResetForm()
    {
        Model = new EmployeeDto();
        selectedPost = "";
        Error = "";
        FormRef?.Reset();
        StateHasChanged();
    }
}