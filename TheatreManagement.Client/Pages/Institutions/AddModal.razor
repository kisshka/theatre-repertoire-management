@using AntDesign
@using Microsoft.AspNetCore.Components.Forms
@using TheatreManagement.Shared.Helpers
@using TheatreManagement.Shared.DTOs.Events

<Modal Visible="@Visible"
       OkButtonProps="@(new ButtonProps { Disabled = Submitting })"
       Title="Добавление учреждения"
       OnOk="HandleOk"
       OnCancel="HandleCancel"
       ConfirmLoading="Submitting"
       MaskClosable="@false">

    <Form Model="@Model"
          OnFinishFailed="@OnFinishFailed"
          OnFinish="@OnFinish"
          @ref="@FormRef">

        <FormItem Label="Тип учреждения" Required>
            <SelectWithAddingItems @bind-SelectedId="selectedInstitutionTypeId"
                                   DataSource="@institutionTypes"
                                   OnDelete="institutionTypesDelete"
								   Placeholder="Выберите тип учреждения"
                                   FieldLabel="тип учреждения"
                                   OnSave="SaveinstitutionTypes" />
        </FormItem>

        <FormItem Label="Название" Required>
            <Input @bind-Value="@context.Name" />
        </FormItem>

        <FormItem Label="Город">
            <Input @bind-Value="@context.Town" />
        </FormItem>

        <FormItem Label="Улица">
            <Input @bind-Value="@context.Street" />
        </FormItem>

        <FormItem Label="Дом">
            <Input @bind-Value="@context.House" />
        </FormItem>

        <FormItem Label="Телефон">
            <Input @bind-Value="@context.PhoneNumber" />
        </FormItem>

        <FormItem Label="Комментарий">
            <TextArea @bind-Value="@context.Comment"
                      Rows="3"
                      Placeholder="Дополнительная информация об учреждении" />
        </FormItem>

        @if (!string.IsNullOrEmpty(Error))
        {
            <Alert Type="AlertType.Error" Message="@Error" Banner />
        }

    </Form>
</Modal>

@code {
	[Parameter] public bool Visible { get; set; }
	[Parameter] public EventCallback<bool> VisibleChanged { get; set; }
	[Parameter] public EventCallback OnSuccess { get; set; }

	[Inject] private InstitutionService institutionService { get; set; }
	[Inject] private InstitutionTypeService institutionTypeService { get; set; }
	[Inject] private IMessageService messageService { get; set; }

	private Form<InstitutionDto> FormRef { get; set; }
	private InstitutionDto Model { get; set; } = new();

	private string Error { get; set; } = "";
	private bool Submitting { get; set; } = false;

	// Для типа учреждения 
	private List<Guide> institutionTypes = new();
	private int selectedInstitutionTypeId;

	protected override async Task OnInitializedAsync()
	{
		await LoadInstitutionTypes();
	}

	protected override async Task OnParametersSetAsync()
	{
		if (Visible)
		{
			ResetForm();
			await LoadInstitutionTypes();
		}
	}

	private async Task LoadInstitutionTypes()
	{
		try
		{
			institutionTypes = await institutionService.GetAllInstitutionTypesAsync();
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Ошибка загрузки типов учреждений: {ex.Message}");
		}
	}

	private async Task OnFinish(EditContext editContext)
	{
		if (Submitting) return;

		Submitting = true;
		StateHasChanged();

		try
		{
			Error = "";

			if (selectedInstitutionTypeId == 0)
			{
				Error = "Выберите тип учреждения";
				return;
			}

			Model.InstitutionTypeId = selectedInstitutionTypeId;

			await institutionService.CreateInstitutionAsync(Model);

			messageService.Success("Учреждение успешно добавлено!");

			Visible = false;
			await VisibleChanged.InvokeAsync(false);
			await OnSuccess.InvokeAsync();

			ResetForm();
		}
		catch (Exception ex)
		{
			Error = ex.Message;
			StateHasChanged();
		}
		finally
		{
			Submitting = false;
			StateHasChanged();
		}
	}

	private void OnFinishFailed(EditContext editContext)
	{
		Console.WriteLine($"Failed");
	}

	private async Task HandleOk()
	{
		if (FormRef != null)
		{
			FormRef.Submit();
		}
	}

	private async Task HandleCancel()
	{
		Visible = false;
		await VisibleChanged.InvokeAsync(false);
		ResetForm();
	}

	private void ResetForm()
	{
		Model = new InstitutionDto();
		selectedInstitutionTypeId = 0;
		Error = "";
		FormRef?.Reset();
		StateHasChanged();
	}

	private async Task institutionTypesDelete()
	{
		await institutionTypeService.DeleteInstitutionTypeAsync(selectedInstitutionTypeId);
		selectedInstitutionTypeId = 0;
		await LoadInstitutionTypes();
	}

	private async Task SaveinstitutionTypes(string name)
	{
		if (string.IsNullOrWhiteSpace(name)) return;

		if (selectedInstitutionTypeId == 0)
		{
			await institutionTypeService.AddInstitutionTypeAsync(name);
		}
		else
		{
			await institutionTypeService.UpdateInstitutionTypeAsync(selectedInstitutionTypeId, name);
		}
		await LoadInstitutionTypes();
	}
}