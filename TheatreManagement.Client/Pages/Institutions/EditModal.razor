@using AntDesign
@using Microsoft.AspNetCore.Components.Forms
@using TheatreManagement.Client.Helpers.SelectItems
@using TheatreManagement.Shared.DTOs

<Modal Visible="@Visible"
       OkButtonProps="@(new ButtonProps { Disabled = Submitting })"
       Title="Редактирование учреждения"
       OnOk="HandleOk"
       OnCancel="HandleCancel"
       ConfirmLoading="Submitting"
       MaskClosable="@false">

    <Form Model="@Model"
          OnFinishFailed="@OnFinishFailed"
          OnFinish="@OnFinish"
          @ref="@FormRef">

        <FormItem Label="Введите название" Required>
            <Input @bind-Value="@context.Name" />
        </FormItem>
        <FormItem Label="Введите город" Required>
            <Input @bind-Value="@context.Town" />
        </FormItem>
        <FormItem Label="Введите улицу">
            <Input @bind-Value="@context.Street" />
        </FormItem>
        <FormItem Label="Введите дом">
            <Input @bind-Value="@context.House" />
        </FormItem>
    </Form>
</Modal>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }
    [Parameter] public int InstitutionId { get; set; }

    [Inject] private InstitutionService institutionService { get; set; }

    private Form<InstitutionDto> FormRef { get; set; }
    private InstitutionDto Model { get; set; } = new();

    private string Error { get; set; } = "";
    private bool Submitting { get; set; } = false;

    protected override async Task OnParametersSetAsync()
    {
        if (Visible)
        {
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        var employee = await institutionService.GetInstitutionAsync(InstitutionId);

        Model = employee;

        StateHasChanged();
    }

    private async Task OnFinish(EditContext editContext)
    {
        if (Submitting) return;

        Submitting = true;
        StateHasChanged();

        try
        {
            await institutionService.UpdateInstitutionAsync(Model);

            Visible = false;
            await VisibleChanged.InvokeAsync(false);
            await OnSuccess.InvokeAsync();

            ResetForm();
        }
        catch (Exception ex)
        {
            Error = ex.Message;
            StateHasChanged();
        }
        finally
        {
            Submitting = false;
            StateHasChanged();
        }
    }

    private void OnFinishFailed(EditContext editContext)
    {
        Console.WriteLine($"Failed");
    }

    private async Task HandleOk()
    {
        if (FormRef != null)
        {
            FormRef.Submit();
        }
    }

    private async Task HandleCancel()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
        ResetForm();
    }

    private void ResetForm()
    {
        Model = new InstitutionDto();
        Error = "";
        FormRef?.Reset();
        StateHasChanged();
    }
}