@page "/users"
@using TheatreManagement.Shared.DTOs
@using TheatreManagement.Client.Services


<PageTitle>Список пользователей</PageTitle>

<PageHeader>
        <PageHeaderTitle>Список пользователей</PageHeaderTitle>
        <PageHeaderExtra>
            <Button Type="ButtonType.Primary">Архив
            <Icon Type="@IconType.Outline.Right" />
            </Button>
        </PageHeaderExtra>
    </PageHeader>

@* Добавление пользователя *@
<div class="table-page-header">
    <Button Type="ButtonType.Primary" OnClick="ShowModalWithService">
        <Icon Type="@IconType.Outline.Plus" />
    </Button>

   <Search Placeholder="Введите ФИО пользователя"  EnterButton="true"/>

    <Button Type="ButtonType.Default">
        <Icon Type="@IconType.Fill.Filter"/>
    </Button>
</div>

<Table TItem="Data" DataSource="@data" PageSize="10">
    @foreach (var column in columns)
    {
        <Column TData="object" DataIndex="@column"></Column>
    }
</Table>

@inject AuthenticationStateProvider provider
@inject ModalService ModalService;
@inject NavigationManager navManager
@code {
@*Модальное окно*@

    RenderFragment FormTemplate()
    {
        return 
        @<Form Model="@model"
              OnFinish="OnFinish"
              OnFinishFailed="OnFinishFailed"
              @ref="@_form">

            <div>
            @if(error.Length > 0)
            {
                <Alert Type="AlertType.Error"
                    Message="@error"
                    Banner />
            }
            </div>

        <FormItem Label="Введите фамилию">
            <Input @bind-Value="@context.Surname" />
        </FormItem>
        <FormItem Label="Введите имя">
            <Input @bind-Value="@context.Name" />
        </FormItem>
        <FormItem Label="Введите отчество">
            <Input @bind-Value="@context.FatherName" />
        </FormItem>
        <FormItem Label="Введите e-mail">
            <Input @bind-Value="@context.Email" />
        </FormItem>
        <FormItem Label="Введите пароль">
                <InputPassword @bind-Value="@context.Password"/>
        </FormItem>
        <FormItem Label="Подтвердите пароль">
                <InputPassword @bind-Value="@context.ConfirmPassword"/>
        </FormItem>
        </Form>
    ;
    }

    bool _visible = false;
    bool _submitting = false;
    private Form<RegisterModel> _form;

    private RegisterModel model = new();

    public string error = "";

    private async Task HandleOk(MouseEventArgs e)
    {
        if (!_form.Validate())
        {
            return;
        }
        _submitting = true;
        await Task.Delay(1000);
        _form.Submit();
        _visible = false;
    }

    private void HandleCancel(MouseEventArgs e)
    {
        _visible = false;
    }

    private void OnFinish(EditContext editContext)
    {
        _submitting = false;
        _visible = false;
    }

    private void OnFinishFailed(EditContext editContext)
    {
        Console.WriteLine($"Failed:{JsonSerializer.Serialize(model)}");
    }

    private void ShowModalWithService()
    {
        ModalRef modalRef = default;
        modalRef = ModalService.CreateModal(new()
        {
            Title = "Добавление пользователя",
            Content = FormTemplate(),

            OnOk = async e =>
            {
                modalRef?.SetConfirmLoading(true);
                await Task.Delay(1000);
                if (!_form.Validate())
                {
                    modalRef?.SetConfirmLoading(false);
                    return;
                }

                _form.Submit();
                await RegisterAsync();

                await modalRef.CloseAsync();

                 _form.Reset();
            },

            OnCancel = async e =>
            {   
                if (!_form.IsModified || await ModalService.ConfirmAsync(new() { Content = "Вы уверены, что не хотите сохранить изменения?" }))
                {   
                    await modalRef.CloseAsync();
                     _form.Reset();
                }
            },
        });
    }
@* Регистрация *@
private async Task RegisterAsync() {

    var authStateProvider = (CustomAuthStateProvider)provider;

    var response = await authStateProvider.RegisterAsync(model);
    if (response.Succeeded) {
        _form.Reset();
    }
    else {
        error = "Что-то пошло не так";
        }
}

@* Временные данные для заполнения таблиц *@
    string[] columns = { "FullName", "Role"};

    Data[] data = new Data[100];

    protected override void OnInitialized()
    {
        for (int i = 0; i < 100; i++)
        {
            data[i] = new Data()
            {
                Key = i.ToString(),
                FullName = $"Иванов Иван Иванович{i}",
                Role = "Актер"
            };
        }
    }
   List<Data> options = new List<Data>();
    public class Data
    {
        [DisplayName("Key")]
        public string? Key { get; set; }

        [DisplayName("ФИО")]
        public string? FullName { get; set; }

        [DisplayName("Роль")]
        public string? Role { get; set; }
    }
}


